generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String          @id @default(uuid())
  email                     String          @unique
  password                  String          @default("")
  displayName               String?
  googleId                  String?         @unique
  authProvider              String          @default("credentials")
  emailNotificationsEnabled Boolean         @default(true)
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  alerts                    AlertRule[]
  notificationDeliveries    NotificationDelivery[]
  watchlist                 WatchlistItem[]
}

model TrackedItem {
  id               String              @id @default(uuid())
  cardId           String?             @unique
  name             String
  setName          String
  number           String?
  type             String              @default("CARD")
  imageUrl         String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  lastPriceCheckAt DateTime?
  priorityScore    Float               @default(0)
  alerts           AlertRule[]
  prices           PriceSnapshot[]
  analysis         TechnicalAnalysis[]
  watchlistEntries WatchlistItem[]
}

model EtbCatalogEntry {
  id               String   @id @default(uuid())
  trackedId        String   @unique
  sourceSetId      String?
  name             String
  setName          String
  imageUrl         String?
  ebayMedianPrice  Float?
  ebayLowPrice     Float?
  ebaySampleSize   Int?
  ebayListingUrl   String?
  isValidated      Boolean  @default(false)
  lastValidatedAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isValidated, lastValidatedAt])
}

model PriceSnapshot {
  id             String      @id @default(uuid())
  trackedItemId  String
  date           DateTime    @default(now())
  fairValue      Float?
  tcgplayerPrice Float?
  ebayPrice      Float?
  ebaySampleSize Int?
  volume         Int?
  createdAt      DateTime    @default(now())
  ebayLowPrice   Float?
  ebayLowListingUrl String?
  isSynthetic    Boolean     @default(false)
  item           TrackedItem @relation(fields: [trackedItemId], references: [id], onDelete: Cascade)

  @@index([trackedItemId, date])
}

model TechnicalAnalysis {
  id            String      @id @default(uuid())
  trackedItemId String
  date          DateTime    @default(now())
  ema8          Float?
  ema20         Float?
  ema50         Float?
  macd          Float?
  signalLine    Float?
  trend         String      @default("NEUTRAL")
  createdAt     DateTime    @default(now())
  item          TrackedItem @relation(fields: [trackedItemId], references: [id], onDelete: Cascade)

  @@index([trackedItemId, date])
}

model AlertRule {
  id            String      @id @default(uuid())
  userId        String
  trackedItemId String
  condition     String
  thresholdData String
  channels      String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  item          TrackedItem @relation(fields: [trackedItemId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WatchlistItem {
  id            String      @id @default(uuid())
  userId        String
  trackedItemId String
  createdAt     DateTime    @default(now())
  item          TrackedItem @relation(fields: [trackedItemId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackedItemId])
  @@index([trackedItemId, createdAt])
}

model NotificationDelivery {
  id            String   @id @default(uuid())
  userId        String
  trackedItemId String?
  signalKey     String
  signalLabel   String
  signalTitle   String
  signalValue   String
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, signalKey])
  @@index([userId, createdAt])
  @@index([trackedItemId, createdAt])
}
